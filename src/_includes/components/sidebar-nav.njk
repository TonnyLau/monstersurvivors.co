{% macro icon(slug) %}
{% set key = slug %}
<span class="sidebar-nav__icon" aria-hidden="true">
  {% if key == "home" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M5 15 16 6l11 9v11a2 2 0 0 1-2 2h-6v-8h-6v8H7a2 2 0 0 1-2-2V15z"/></svg>
  {% elif key == "new" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M16 3l3.5 8.7 9.3.7-7.1 6.1 2.2 9.1-7.9-4.9-7.9 4.9 2.2-9.1-7.1-6.1 9.3-.7L16 3z"/></svg>
  {% elif key == "2-player" %}
    <svg viewBox="0 0 32 32" focusable="false"><circle cx="11" cy="10" r="5"/><circle cx="22" cy="12" r="4"/><path d="M3 27c1.2-6.2 4-9 8-9s6.8 2.8 8 9H3zm15.5 0c.5-3.3 2.2-5.5 4.9-6.2 3.1.4 5 2.6 5.6 6.2H18.5z"/></svg>
  {% elif key == "2d" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M5 8h22v16H5V8zm5 5v6h12v-6H10z"/></svg>
  {% elif key == "3d" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="m16 3 11 6v14l-11 6-11-6V9l11-6zm0 4.5-6.7 3.7 6.7 3.8 6.7-3.8L16 7.5zm-7 7.2v5.9l5 2.8v-5.9l-5-2.8zm9 8.7 5-2.8v-5.9l-5 2.8v5.9z"/></svg>
  {% elif key == "action" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="m17 2-9 15h7l-2 13 11-17h-8l1-11z"/></svg>
  {% elif key == "adventure" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M16 3 5 28l11-5 11 5L16 3zm0 8 4.4 10-4.4-2-4.4 2L16 11z"/></svg>
  {% elif key == "arcade" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M7 12h18l3 13a3 3 0 0 1-3 4c-2.5 0-3.8-2.6-5.2-4H12.2C10.8 26.4 9.5 29 7 29a3 3 0 0 1-3-4l3-13zm4-7h4v7h-4V5zm-1 13v3H7v3h3v3h3v-3h3v-3h-3v-3h-3zm11.5 2.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm4 5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg>
  {% elif key == "car" or key == "drift" or key == "driving" or key == "racing" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M8 12 11 6h10l3 6 3 2v9h-3a4 4 0 0 1-8 0h-1a4 4 0 0 1-8 0H4v-9l4-2zm3.1-3-1.6 3h13L20.9 9h-9.8zM9 25a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm14 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg>
  {% elif key == "clicker" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M15 3a4 4 0 0 1 4 4v6h1a4 4 0 0 1 4 4v11H11l-6-8a3 3 0 0 1 4.8-3.6L11 18V7a4 4 0 0 1 4-4z"/></svg>
  {% elif key == "crazy" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M16 3c6 0 11 4.2 11 10.2 0 7.8-8 8-8 13.8h-6c0-8.2 7.2-7.8 7.2-13.8 0-2.4-1.7-4-4.2-4-2.9 0-4.5 2-4.8 4.8H5C5.5 7.6 9.8 3 16 3zm-3 24h6v3h-6v-3z"/></svg>
  {% elif key == "girl" or key == "kids" %}
    <svg viewBox="0 0 32 32" focusable="false"><circle cx="16" cy="10" r="6"/><path d="M6 29c1.1-7 4.4-10.5 10-10.5S24.9 22 26 29H6z"/></svg>
  {% elif key == "io-games" or key == "multiplayer" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M16 3a13 13 0 1 0 0 26 13 13 0 0 0 0-26zm0 4c1.3 1.7 2.2 3.8 2.6 6h-5.2c.4-2.2 1.3-4.3 2.6-6zM7.7 18a9 9 0 0 1 0-4h4.1a19 19 0 0 0 0 4H7.7zm1.9 4h3.2c.4 1.3 1 2.5 1.7 3.6A9.1 9.1 0 0 1 9.6 22zm3.2-12H9.6a9.1 9.1 0 0 1 4.9-3.6A16 16 0 0 0 12.8 10zm3.2 15c-1.1-1.4-1.9-3-2.4-5h4.8c-.5 2-1.3 3.6-2.4 5zm3.3-7h-6.6a14.2 14.2 0 0 1 0-4h6.6a14.2 14.2 0 0 1 0 4zm-1.8 7.6c.7-1.1 1.3-2.3 1.7-3.6h3.2a9.1 9.1 0 0 1-4.9 3.6zM20.2 18a19 19 0 0 0 0-4h4.1a9 9 0 0 1 0 4h-4.1zm-.9-8c-.4-1.3-1-2.5-1.7-3.6a9.1 9.1 0 0 1 4.9 3.6h-3.2z"/></svg>
  {% elif key == "minecraft" or key == "pixel" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M5 5h22v22H5V5zm5 5v5h5v-5h-5zm7 0v5h5v-5h-5zm-7 7v5h12v-5H10z"/></svg>
  {% elif key == "mobile" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M11 3h10a3 3 0 0 1 3 3v20a3 3 0 0 1-3 3H11a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3zm1 4v17h8V7h-8zm3 19v1h2v-1h-2z"/></svg>
  {% elif key == "puzzle" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M5 5h9v6a3 3 0 1 0 4 0V5h9v9h-6a3 3 0 1 0 0 4h6v9h-9v-6a3 3 0 1 0-4 0v6H5v-9h6a3 3 0 1 0 0-4H5V5z"/></svg>
  {% elif key == "shooting" or key == "sniper" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M16 3h2v6a7 7 0 0 1 5 5h6v2h-6a7 7 0 0 1-5 5v6h-2v-6a7 7 0 0 1-5-5H5v-2h6a7 7 0 0 1 5-5V3zm1 10a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></svg>
  {% elif key == "simulator" or key == "strategy" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M6 8h20v4H6V8zm3 7h14v4H9v-4zm-3 7h20v4H6v-4zM4 5h4v4H4V5zm20 0h4v4h-4V5zM4 23h4v4H4v-4zm20 0h4v4h-4v-4z"/></svg>
  {% elif key == "sports" %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M16 3a13 13 0 1 0 0 26 13 13 0 0 0 0-26zm7.5 6.2a10 10 0 0 1 2.2 4.2l-5.2-2.7-1.1-4.6a10 10 0 0 1 4.1 3.1zM16 13l4 3-1.6 4.8h-4.8L12 16l4-3zm-3.4-6.9-1.1 4.6-5.2 2.7a10 10 0 0 1 6.3-7.3zM6.2 18l4.3.4 2.2 4.2-2.8 3.1A10 10 0 0 1 6.2 18zm12.1 7.8h-4.6l1.8-2h1l1.8 2zm3.8-.1-2.8-3.1 2.2-4.2 4.3-.4a10 10 0 0 1-3.7 7.7z"/></svg>
  {% else %}
    <svg viewBox="0 0 32 32" focusable="false"><path d="M16 3 5 9v14l11 6 11-6V9L16 3zm0 5 6 3.2v9.6L16 24l-6-3.2v-9.6L16 8z"/></svg>
  {% endif %}
</span>
{% endmacro %}

{% macro navItem(href, label, slug, count, current) %}
<a href="{{ href }}"{% if current %} aria-current="page"{% endif %}>
  {{ icon(slug) }}
  <span class="sidebar-nav__label">{{ label }}</span>
  {% if count is not none %}
    <span class="sidebar-nav__count">{{ count }}</span>
  {% endif %}
</a>
{% endmacro %}

{% macro catalogSidebar(tags, pageUrl, currentTagSlug) %}
<aside class="sidebar-nav sidebar-nav__rail" id="game-sidebar" aria-label="Game tags">
  <a class="sidebar-nav__home" href="/"{% if pageUrl == "/" %} aria-current="page"{% endif %}>
    {{ icon("home") }}
    <span class="sidebar-nav__label">Home</span>
  </a>
  <nav>
    {{ navItem("/new-games/", "New", "new", null, pageUrl == "/new-games/") }}
    {% for tag in tags %}
      {{ navItem(tag.href, tag.label, tag.slug, tag.count, tag.slug == currentTagSlug) }}
    {% endfor %}
    <a class="sidebar-nav__all" href="/all-tags/"{% if pageUrl == "/all-tags/" %} aria-current="page"{% endif %}>
      {{ icon("all-tags") }}
      <span class="sidebar-nav__label">All Tags</span>
    </a>
  </nav>
</aside>
{% endmacro %}
