---
layout: layouts/base.njk
pagination:
  data: liveGames
  size: 1
  alias: game
permalink: "/games/{{ game.slug }}/"
eleventyComputed:
  title: "{{ game.seo.title }}"
  description: "{{ game.seo.description }}"
---
{% import "components/game-card.njk" as cards %}
{% set currentLocale = locale | default(site.locale) | default("en-US") %}
{% set primaryTag = games.allTags | tagBySlug(game.primaryTag) %}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span>/</span>
  <a href="/t/{{ primaryTag.slug }}/">{{ primaryTag.label }}</a>
  <span>/</span>
  <span>{{ game.title }}</span>
</nav>
<nav class="breadcrumb breadcrumb__mobile" aria-label="Mobile breadcrumb">
  <span>...</span>
  <span>/</span>
  <span>{{ game.title }}</span>
</nav>

<section class="page-hero">
  <h1>{{ game.title }}</h1>
  <p>{{ game.description }}</p>
</section>

<section class="section">
  <div class="game-play-header">
    <button type="button" class="game-frame__fullscreen" data-fullscreen-button aria-label="Enter fullscreen">
      <svg class="game-frame__fullscreen-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M4 9V4h5v2H6v3H4Zm14 0V6h-3V4h5v5h-2ZM4 20v-5h2v3h3v2H4Zm11 0v-2h3v-3h2v5h-5Z" fill="currentColor"/>
      </svg>
      <span>Fullscreen</span>
    </button>
  </div>
  <div class="game-frame">
    <div class="game-frame__loading">Loading game...</div>
    <iframe
      src="{{ game.iframe.src }}"
      title="Play {{ game.title }} Online"
      loading="lazy"
      sandbox="{{ game.iframe.sandbox or 'allow-scripts allow-same-origin allow-pointer-lock' }}"
      allow="{{ game.iframe.allow or 'fullscreen; gamepad; autoplay; pointer-lock' }}"
      allowfullscreen>
    </iframe>
  </div>
</section>

<section class="section game-guide" aria-label="{{ game.title }} guide sections">
  <article class="guide-card guide-card--wide">
    <h2>Overview</h2>
    {% for paragraph in game.guide.overview %}
      <p>{{ paragraph }}</p>
    {% endfor %}
  </article>

  <article class="guide-card">
    <h2>Controls</h2>
    <dl class="control-list">
      {% for control in game.guide.controls %}
        <div class="control-list__item">
          <dt><span class="control-key">{{ control.input }}</span></dt>
          <dd>{{ control.action }}</dd>
        </div>
      {% endfor %}
    </dl>
  </article>

  <article class="guide-card">
    <h2>How to Play {{ game.title }}</h2>
    <ol class="how-to-list">
      {% for step in game.guide.howToPlay %}
        <li>
          <h3>{{ step.title }}</h3>
          <p>{{ step.text }}</p>
        </li>
      {% endfor %}
    </ol>
  </article>

  <article class="guide-card">
    <h2>Tips &amp; Tricks</h2>
    <ul class="tips-list">
      {% for tip in game.guide.tips %}
        <li>{{ tip }}</li>
      {% endfor %}
    </ul>
  </article>

  <article class="guide-card">
    <h2>Game Features</h2>
    <div class="feature-list guide-feature-list">
      {% for feature in game.features %}
        <span>{{ feature }}</span>
      {% endfor %}
    </div>
  </article>

  <article class="guide-card">
    <h2>Instructions</h2>
    <ul class="instruction-list">
      {% for instruction in game.instructions %}
        <li>{{ instruction }}</li>
      {% endfor %}
    </ul>
  </article>

  {% if game.guide.longTailTerms and game.guide.longTailTerms.length %}
    <article class="guide-card">
      <h2>Related Searches</h2>
      <div class="related-search-list">
        {% for term in game.guide.longTailTerms %}
          <span>{{ term }}</span>
        {% endfor %}
      </div>
    </article>
  {% endif %}

  <article class="guide-card guide-card--wide">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      {% for item in game.faq %}
        <article class="faq-item">
          <h3>{{ item.question }}</h3>
          <p>{{ item.answer }}</p>
        </article>
      {% endfor %}
    </div>
  </article>
</section>

<section class="section section--surface">
  <div class="section__heading">
    <h2>More {{ primaryTag.label }} Games</h2>
  </div>
  <div class="game-grid">
    {% for related in game.relatedGames | relatedGameRecords(games.games, currentLocale) %}
      {{ cards.card(related, false) }}
    {% endfor %}
  </div>
</section>

<script type="application/ld+json">{{ {"@context":"https://schema.org","@type":"VideoGame","name":game.title,"description":game.description,"url":site.domain + page.url,"genre":primaryTag.label,"operatingSystem":"Web browser","applicationCategory":"Game"} | json | safe }}</script>
<script type="application/ld+json">{{ {"@context":"https://schema.org","@type":"FAQPage","mainEntity":game.faq} | json | safe }}</script>
